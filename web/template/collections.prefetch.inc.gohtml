<!-- BEGIN prefetch images -->
{{range $area, $items := .Result}}
    {{range $key, $item := $items}}
        {{if $item.Content.Poster}}
            {{$image := $item.Content.Poster}}
            <link rel="preload" as="image"
                  href="{{medialink $image.Uri "resize" "size260x260/formatWEBP" false}}">
        {{end}}
    {{end}}
{{end}}
<!-- END prefetch images -->
